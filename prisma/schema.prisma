datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

// ==========================================
// ENUMS (Viết tách biệt, không lồng nhau)
// ==========================================

enum AuthProvider {
  email
  google
  apple
}

enum UserRole {
  admin
  member
  guest
}

enum ThemeMode {
  light
  dark
  system
}

enum Language {
  vi
  en
}

enum GroupType {
  trip
  household
  general
}

enum GroupCurrency {
  VND
  USD
  EUR
  JPY
}

enum MemberRole {
  admin
  guest
}

enum MemberStatus {
  pending
  accepted
}

enum BillCategory {
  food
  transport
  accommodation
  entertainment
  shopping
  other
}

enum SplitMethod {
  equal
  percentage
  custom
  manual
}

enum PaymentStatus {
  pending
  confirmed
  cancelled
}

enum TripStatus {
  planning
  ongoing
  completed
}

enum PublisherType {
  user
  business
}

enum LocationCategory {
  restaurant
  shopping
  attraction
  accommodation
  transport
  other
}

enum TravelMode {
  driving
  walking
  transit
  bicycling
  flight
}

enum NotificationType {
  payment_request
  payment_confirmed
  group_invite
  new_bill
  balance_update
}

enum FeedbackType {
  bug
  feature
  other
}

// ==========================================
// MODELS
// ==========================================

model User {
  id               String         @id @default(uuid())
  displayName      String
  email            String         @unique
  password         String?        // Thêm dòng này (có dấu ? để hỗ trợ cả Google login sau này)
  avatarUrl        String?
  provider         AuthProvider
  bio              String?
  birthday         DateTime?      @db.Date
  gender           String?
  coverUrl         String?
  phone            String?
  address          String?
  socialLinks      Json?
  groupCount       Int            @default(0)
  bankAccountCount Int            @default(0)
  theme            ThemeMode      @default(system)
  language         Language       @default(vi)
  appVersion       String         @default("1.0.0")
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  // Mối quan hệ 1-N: Một User chỉ thuộc về đúng 1 Role
  roleId       Int
  role         Role       @relation(fields: [roleId], references: [id])
  bankAccounts     BankAccount[]
  groupsCreated    Group[]        @relation("GroupCreator")
  groupMemberships GroupMember[]
  tripsCreated     Trip[]         @relation("TripCreator")
  tripMemberships  TripMember[]
  notifications    Notification[]
  feedbacks        Feedback[]
}

model Role {
  id          Int              @id @default(autoincrement())
  name        String           @unique // Ví dụ: "ADMIN", "USER", "MANAGER"
  description String?          
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  // Mối quan hệ: Một Role có nhiều Users
  users       User[]
  
  // Mối quan hệ N-N: Một Role có thể có nhiều Permissions
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          Int              @id @default(autoincrement())
  name        String           @unique // Ví dụ: "CREATE_TOUR", "DELETE_USER"
  description String?          
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  // Mối quan hệ N-N với Role
  roles       RolePermission[]

  @@map("permissions")
}

// Bảng trung gian duy nhất còn lại: Nối giữa Role và Permission
model RolePermission {
  roleId       Int
  permissionId Int
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model BankAccount {
  id            String   @id @default(uuid())
  userId        String
  bankName      String
  accountNumber String
  accountHolder String
  isDefault     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Group {
  id          String        @id @default(uuid())
  name        String
  type        GroupType
  currency    GroupCurrency
  coverUrl    String?
  createdBy   String
  memberCount Int           @default(1)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  creator  User          @relation("GroupCreator", fields: [createdBy], references: [id])
  members  GroupMember[]
  bills    Bill[]
  payments Payment[]
  trips    Trip[]
}

model GroupMember {
  id        String       @id @default(uuid())
  groupId   String
  userId    String?
  name      String
  avatarUrl String?
  role      MemberRole   @default(guest)
  status    MemberStatus @default(pending)
  joinedAt  DateTime     @default(now())

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User? @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model Bill {
  id          String        @id @default(uuid())
  groupId     String
  title       String
  amount      Float
  currency    GroupCurrency
  category    BillCategory
  date        DateTime      @default(now())
  imageUrls   String[]
  paidBy      String
  splitMethod SplitMethod
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  group    Group        @relation(fields: [groupId], references: [id], onDelete: Cascade)
  splits   BillSplit[]
  payments Payment[]
}

model BillSplit {
  id            String   @id @default(uuid())
  billId        String
  groupMemberId String
  shareValue    Float
  calculatedOwe Float
  isPaid        Boolean  @default(false)

  bill Bill @relation(fields: [billId], references: [id], onDelete: Cascade)
}

model Payment {
  id          String        @id @default(uuid())
  groupId     String
  billId      String?
  payerId     String
  receiverId  String
  amount      Float
  currency    GroupCurrency
  status      PaymentStatus @default(pending)
  proofUrl    String?
  note        String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  bill  Bill? @relation(fields: [billId], references: [id], onDelete: SetNull)
}

model Trip {
  id            String        @id @default(uuid())
  groupId       String?
  title         String
  description   String?
  startDate     DateTime      @db.Date
  endDate       DateTime      @db.Date
  coverImageUrl String?
  currency      GroupCurrency
  status        TripStatus    @default(planning)
  isPublic      Boolean       @default(false)
  createdBy     String
  viewCount     Int           @default(0)
  likeCount     Int           @default(0)
  clonedFromId  String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  group        Group?        @relation(fields: [groupId], references: [id], onDelete: SetNull)
  creator      User          @relation("TripCreator", fields: [createdBy], references: [id])
  members      TripMember[]
  destinations Destination[]
}

model TripMember {
  id       String   @id @default(uuid())
  tripId   String
  userId   String
  isOwner  Boolean  @default(false)
  joinedAt DateTime @default(now())

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Destination {
  id          String   @id @default(uuid())
  tripId      String
  name        String
  description String?
  sequence    Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  trip   Trip        @relation(fields: [tripId], references: [id], onDelete: Cascade)
  places PlaceItem[]
}

model PlaceItem {
  id               String           @id @default(uuid())
  destinationId    String
  name             String
  latitude         Float
  longitude        Float
  address          String?
  category         LocationCategory
  note             String?
  visitTime        DateTime?
  durationMinutes  Int?
  cost             Float            @default(0)
  sequence         Int
  travelModeToNext TravelMode?
  distanceToNext   Float?
  durationToNext   Int?

  destination Destination @relation(fields: [destinationId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  isRead    Boolean          @default(false)
  data      Json?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Feedback {
  id          String       @id @default(uuid())
  userId      String
  type        FeedbackType
  title       String
  content     String
  deviceInfo  Json?
  status      String       @default("open")
  adminNotes  String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}