datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

// ==========================================
// ENUMS (Viết tách biệt, không lồng nhau)
// ==========================================

enum AuthProvider {
  email
  google
  apple
}

enum UserRole {
  admin
  member
  guest
}

enum ThemeMode {
  light
  dark
  system
}

enum Language {
  vi
  en
}

enum GroupType {
  trip
  household
  general
}

enum GroupCurrency {
  VND
  USD
  EUR
  JPY
}

enum MemberRole {
  admin
  guest
  member
}

enum MemberStatus {
  pending
  accepted
}

enum BillCategory {
  food
  transport
  accommodation
  entertainment
  shopping
  other
}

enum SplitMethod {
  equal
  percentage
  custom
  manual
}

enum PaymentStatus {
  pending
  confirmed
  cancelled
}

enum TripStatus {
  planning
  ongoing
  completed
}

enum PublisherType {
  user
  business
}

enum LocationCategory {
  restaurant
  shopping
  attraction
  accommodation
  transport
  other
}

enum TravelMode {
  driving
  walking
  transit
  bicycling
  flight
}

enum NotificationType {
  payment_request
  payment_confirmed
  group_invite
  new_bill
  balance_update
}

enum FeedbackType {
  bug
  feature
  other
}

enum BookingStatus {
  PENDING // Đang chờ thanh toán
  CONFIRMED // Đã thanh toán, giữ chỗ thành công
  CANCELLED // Đã hủy (do khách hoặc do quá hạn thanh toán)
  COMPLETED // Đã đi tour xong
}

enum BookingPaymentStatus {
  UNPAID // Chưa thanh toán
  PAID // Đã thanh toán
  REFUNDED // Đã hoàn tiền (khi khách hủy tour)
  FAILED // Giao dịch lỗi
}

enum PaymentMethod {
  VNPAY
  MOMO
  BANK_TRANSFER // Chuyển khoản thủ công
}

enum TicketStatus {
  VALID // Vé hợp lệ, chưa sử dụng
  USED // Đã quét QR code / Đã check-in
  CANCELLED // Vé bị hủy
}

// ==========================================
// MODELS
// ==========================================

model User {
  id               String         @id @default(uuid())
  displayName      String
  email            String         @unique
  password         String? // Thêm dòng này (có dấu ? để hỗ trợ cả Google login sau này)
  avatarUrl        String?
  provider         AuthProvider
  bio              String?
  birthday         DateTime?      @db.Date
  gender           String?
  coverUrl         String?
  phone            String?
  address          String?
  socialLinks      Json?
  groupCount       Int            @default(0)
  bankAccountCount Int            @default(0)
  theme            ThemeMode      @default(system)
  language         Language       @default(vi)
  appVersion       String         @default("1.0.0")
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  // Mối quan hệ 1-N: Một User chỉ thuộc về đúng 1 Role
  roleId           Int
  role             Role           @relation(fields: [roleId], references: [id])
  bankAccounts     BankAccount[]
  groupsCreated    Group[]        @relation("GroupCreator")
  groupMemberships GroupMember[]
  tripsCreated     Trip[]         @relation("TripCreator")
  tripMemberships  TripMember[]
  notifications    Notification[]
  feedbacks        Feedback[]
  bookings         Booking[]
}

model Role {
  id          Int      @id @default(autoincrement())
  name        String   @unique // Ví dụ: "ADMIN", "USER", "MANAGER"
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Mối quan hệ: Một Role có nhiều Users
  users User[]

  // Mối quan hệ N-N: Một Role có thể có nhiều Permissions
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          Int      @id @default(autoincrement())
  name        String   @unique // Ví dụ: "CREATE_TOUR", "DELETE_USER"
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Mối quan hệ N-N với Role
  roles RolePermission[]

  @@map("permissions")
}

// Bảng trung gian duy nhất còn lại: Nối giữa Role và Permission
model RolePermission {
  roleId       Int
  permissionId Int
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model BankAccount {
  id            String   @id @default(uuid())
  userId        String
  bankName      String
  accountNumber String
  accountHolder String
  isDefault     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Group {
  id          String        @id @default(uuid())
  name        String
  type        GroupType
  currency    GroupCurrency
  coverUrl    String?
  createdBy   String
  memberCount Int           @default(1)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  creator  User          @relation("GroupCreator", fields: [createdBy], references: [id])
  members  GroupMember[]
  bills    Bill[]
  payments Payment[]
  trips    Trip[]
}

model GroupMember {
  id        String       @id @default(uuid())
  groupId   String
  userId    String?
  name      String
  avatarUrl String?
  role      MemberRole   @default(guest)
  status    MemberStatus @default(pending)
  joinedAt  DateTime     @default(now())

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User? @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model Bill {
  id          String        @id @default(uuid())
  groupId     String
  title       String
  amount      Float
  currency    GroupCurrency
  category    BillCategory
  date        DateTime      @default(now())
  imageUrls   String[]
  paidBy      String
  splitMethod SplitMethod
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  group    Group       @relation(fields: [groupId], references: [id], onDelete: Cascade)
  splits   BillSplit[]
  payments Payment[]
}

model BillSplit {
  id            String  @id @default(uuid())
  billId        String
  groupMemberId String
  shareValue    Float
  calculatedOwe Float
  isPaid        Boolean @default(false)

  bill Bill @relation(fields: [billId], references: [id], onDelete: Cascade)
}

model Payment {
  id         String        @id @default(uuid())
  groupId    String
  billId     String?
  payerId    String
  receiverId String
  amount     Float
  currency   GroupCurrency
  status     PaymentStatus @default(pending)
  proofUrl   String?
  note       String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  bill  Bill? @relation(fields: [billId], references: [id], onDelete: SetNull)
}

model Trip {
  id            String        @id @default(uuid())
  groupId       String?
  title         String
  description   String?
  startDate     DateTime      @db.Date
  endDate       DateTime      @db.Date
  coverImageUrl String?
  currency      GroupCurrency
  status        TripStatus    @default(planning)
  isPublic      Boolean       @default(false)
  createdBy     String
  viewCount     Int           @default(0)
  likeCount     Int           @default(0)
  clonedFromId  String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  group        Group?        @relation(fields: [groupId], references: [id], onDelete: SetNull)
  creator      User          @relation("TripCreator", fields: [createdBy], references: [id])
  members      TripMember[]
  destinations Destination[]

  // 🚀 CÁC TRƯỜNG BỔ SUNG CHO TÍNH NĂNG BÁN TOUR
  isCommercial        Boolean   @default(false) // Đánh dấu đây là tour thương mại để bán
  price               Float? // Giá vé người lớn
  childPrice          Float? // Giá vé trẻ em
  maxCapacity         Int? // Tổng số lượng chỗ (Slots) tối đa bán ra
  currentParticipants Int       @default(0) // Số chỗ đã có người đặt (Dùng để tính Slot còn lại)
  bookingDeadline     DateTime? // Hạn chót nhận đặt chỗ
  termsAndConditions  String? // Điều khoản, chính sách hoàn hủy
  // Quan hệ mới
  bookings            Booking[] // Một chuyến đi có nhiều đơn đặt chỗ
}

model TripMember {
  id       String   @id @default(uuid())
  tripId   String
  userId   String
  isOwner  Boolean  @default(false)
  joinedAt DateTime @default(now())

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Destination {
  id          String   @id @default(uuid())
  tripId      String
  name        String
  description String?
  sequence    Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  trip   Trip        @relation(fields: [tripId], references: [id], onDelete: Cascade)
  places PlaceItem[]
}

model PlaceItem {
  id               String           @id @default(uuid())
  destinationId    String
  name             String
  latitude         Float
  longitude        Float
  address          String?
  category         LocationCategory
  note             String?
  visitTime        DateTime?
  durationMinutes  Int?
  cost             Float            @default(0)
  sequence         Int
  travelModeToNext TravelMode?
  distanceToNext   Float?
  durationToNext   Int?

  destination Destination @relation(fields: [destinationId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  isRead    Boolean          @default(false)
  data      Json?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Feedback {
  id         String       @id @default(uuid())
  userId     String
  type       FeedbackType
  title      String
  content    String
  deviceInfo Json?
  status     String       @default("open")
  adminNotes String?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ==========================================
// THƯƠNG MẠI ĐIỆN TỬ & ĐẶT TOUR (BOOKING)
// ==========================================

model Booking {
  id          String   @id @default(uuid())
  tripId      String
  userId      String? // Người thực hiện đặt tour (giữ lịch sử ngay cả khi user bị xóa)
  bookingDate DateTime @default(now())

  // Thông tin số lượng & giá tiền
  adultCount Int   @default(1)
  childCount Int   @default(0)
  totalPrice Float // Tổng tiền phải thanh toán

  // Trạng thái đơn hàng
  status        BookingStatus        @default(PENDING)
  paymentStatus BookingPaymentStatus @default(UNPAID)
  paymentMethod PaymentMethod?

  // Thông tin liên hệ của người đặt (Có thể lấy từ User hoặc nhập tay khi đặt)
  contactName     String
  contactPhone    String
  contactEmail    String
  specialRequests String? // Ghi chú của khách (Ví dụ: Dị ứng hải sản)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Mối quan hệ
  trip         Trip                 @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user         User?                @relation(fields: [userId], references: [id], onDelete: SetNull)
  transactions BookingTransaction[]
  tickets      Ticket[]
}

// Bảng lưu vết giao dịch qua cổng thanh toán (Bắt buộc phải có để đối soát với VNPAY/Momo)
model BookingTransaction {
  id                   String               @id @default(uuid())
  bookingId            String
  amount               Float // Số tiền giao dịch
  gateway              PaymentMethod // VNPAY, MOMO
  gatewayTransactionId String? // Mã giao dịch trả về từ VNPAY/Momo (Rất quan trọng)
  status               BookingPaymentStatus // Trạng thái của lần thanh toán này
  errorMessage         String? // Ghi nhận lý do lỗi nếu FAILED
  createdAt            DateTime             @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
}

// Bảng Vé điện tử (Xuất ra sau khi thanh toán thành công)
model Ticket {
  id         String       @id @default(uuid())
  bookingId  String
  ticketCode String       @unique // Mã Code tạo ngẫu nhiên (Ví dụ: TOUR-VN83K2). Dùng để gen QR Code
  qrCodeUrl  String? // Link ảnh QR Code lưu trên Cloudinary
  status     TicketStatus @default(VALID)

  // Thông tin hành khách (Có thể là người đặt hoặc bạn bè của người đặt)
  passengerName String
  passengerType String // ADULT (Người lớn) hoặc CHILD (Trẻ em)

  issuedAt DateTime  @default(now())
  usedAt   DateTime? // Thời điểm hướng dẫn viên quét QR Code check-in

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
}
